{
  "name": "git-helper",
  "version": "1.0.0",
  "description": "Smart git operations with conventional commit support",
  "author": "marketplace-team",
  "category": "git",
  "keywords": ["git", "commit", "branch", "merge", "conventional-commits", "changelog", "release"],
  "skills": ["skills/SKILL.md"],
  "mcpServers": {
    "git-helper": {
      "command": "npx",
      "args": ["-y", "@marketplace/git-helper-mcp"],
      "env": {
        "GIT_DEFAULT_BRANCH": "main"
      }
    }
  },
  "compatibility": {
    "copilot-cli": ">=1.0.0",
    "claude-code": ">=1.0.0",
    "cursor": true,
    "windsurf": true
  }
}
